# Copy to `.env` (dev) or `.env.production` (build) and set real values.

# Base URL of the backend API (Next.js app in ./backend/db), including "/api".
# Development default is http://localhost:3001/api.
# In production set this to your live backend, e.g. https://api.helpr.com/api
VITE_API_BASE=http://localhost:3001/api
