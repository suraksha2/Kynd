# Copy this file to `.env.local` and fill in real values. Never commit `.env.local`.

# --- MySQL ---
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=urban_service

# --- Admin session ---
# Long, random value in production, e.g. `openssl rand -hex 32` (min 16 chars).
SESSION_SECRET=

# --- CORS ---
# Comma-separated list of production frontend origins allowed to call this API
# (the customer app and the standalone admin console). Localhost dev origins are
# always allowed. Example:
# ALLOWED_ORIGINS=https://app.helpr.com,https://admin.helpr.com
ALLOWED_ORIGINS=

# --- WhatsApp (Meta Cloud API) ---
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# --- Airwallex payments ---
# 'prod' for live payments, 'demo' for testing.
AIRWALLEX_ENV=prod
# From Airwallex web app > Developer > API keys.
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
# 3-letter ISO 4217 currency code (app prices are in SGD).
PAYMENT_CURRENCY=SGD
